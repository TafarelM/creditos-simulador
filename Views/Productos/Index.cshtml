<h2>Catálogo de Productos de Crédito</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>TEA</th>
            <th>Comisión</th>
            <th>Meses (Min - Max)</th>
            <th>Simular</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var p in Model)
    {
        <tr>
            <td>@p.Nombre</td>
            <td>@(p.Tea * 100)%</td>
            <td>@(p.ComisionPct * 100)%</td>
            <td>@p.MinMeses - @p.MaxMeses</td>
            <td>
                <a class="btn btn-primary" href="@Url.Action("Simulador", "Productos", new { productId = p.Id })">Simular</a>
            </td>
        </tr>
    }
    </tbody>
</table>